{
  "name": "product-scout-ai",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "concurrently \"npm --prefix backend start\" \"npm --prefix frontend start\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
